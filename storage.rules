rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Challenge files: any authenticated user can read (view challenge attachments).
    // Write: any authenticated user (admin uploads; app shows upload only to admins).
    match /challenges/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
